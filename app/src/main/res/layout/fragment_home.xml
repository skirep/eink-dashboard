<?xml version="1.0" encoding="utf-8"?>
<!--
    Home fragment – main dashboard with time, weather, notes, and reading progress
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TIME AND DATE -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:42"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            android:letterSpacing="-0.02" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dilluns, 26 Abril"
            android:textSize="16sp"
            android:textColor="@color/on_background"
            android:layout_marginBottom="16dp" />

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/eink_dark_gray"
            android:layout_marginBottom="16dp" />

        <!-- WEATHER WIDGET -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- Weather header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☁  TEMPS"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_background" />

            </LinearLayout>

            <!-- Current weather -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Temperature -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCurrentTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="17°C"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_background" />

                </LinearLayout>

                <!-- Condition -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvCondition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parcialment ennuvolat"
                        android:textSize="14sp"
                        android:textColor="@color/on_background" />

                    <TextView
                        android:id="@+id/tvFeelsLike"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sensació 16°C"
                        android:textSize="12sp"
                        android:textColor="@color/eink_gray"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Weather details grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Wind -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💨 Vent"
                        android:textSize="11sp"
                        android:textColor="@color/eink_gray" />

                    <TextView
                        android:id="@+id/tvWind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 km/h NE"
                        android:textSize="12sp"
                        android:textColor="@color/on_background" />

                </LinearLayout>

                <!-- Humidity -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧 Humitat"
                        android:textSize="11sp"
                        android:textColor="@color/eink_gray" />

                    <TextView
                        android:id="@+id/tvHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="63%"
                        android:textSize="12sp"
                        android:textColor="@color/on_background" />

                </LinearLayout>

                <!-- Sunrise -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌅 Sortida"
                        android:textSize="11sp"
                        android:textColor="@color/eink_gray" />

                    <TextView
                        android:id="@+id/tvSunrise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="06:45"
                        android:textSize="12sp"
                        android:textColor="@color/on_background" />

                </LinearLayout>

                <!-- Sunset -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌇 Posta"
                        android:textSize="11sp"
                        android:textColor="@color/eink_gray" />

                    <TextView
                        android:id="@+id/tvSunset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20:43"
                        android:textSize="12sp"
                        android:textColor="@color/on_background" />

                </LinearLayout>

            </LinearLayout>

            <!-- 5-day forecast -->
            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Barcelona, Catalunya"
                android:textSize="11sp"
                android:textColor="@color/eink_gray"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/forecastContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="5" />

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/eink_dark_gray"
            android:layout_marginBottom="16dp" />

        <!-- NOTES SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝  NOTES"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/on_background"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/notesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Nova nota"
                android:textSize="14sp"
                android:textColor="@color/eink_gray"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/eink_dark_gray"
            android:layout_marginBottom="16dp" />

        <!-- READING SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖  LLEGINT"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_background"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvReadingTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&quot;Atomic Habits&quot;"
                    android:textSize="14sp"
                    android:textColor="@color/on_background"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvReadingPage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pàgina 47 de 320"
                    android:textSize="12sp"
                    android:textColor="@color/eink_gray" />

            </LinearLayout>

            <!-- Book cover placeholder -->
            <View
                android:layout_width="80dp"
                android:layout_height="100dp"
                android:background="@color/eink_light_gray" />

        </LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/eink_dark_gray"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- BOTTOM MENU -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="☰  MENÚ"
                android:textSize="14sp"
                android:textColor="@color/on_background"
                android:gravity="start" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚙  CONFIGURACIÓ"
                android:textSize="14sp"
                android:textColor="@color/on_background"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
