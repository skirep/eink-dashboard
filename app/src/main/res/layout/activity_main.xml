<?xml version="1.0" encoding="utf-8"?>
<!--
    Root layout for MainActivity.
    The ViewPager2 is configured with USER_INPUT_ENABLED = false so the user
    cannot swipe between pages – navigation is done exclusively with the
    "Anterior" / "Següent" buttons at the bottom.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Page content fills all available space above the nav bar -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Navigation bar: Prev | Page indicator | Next -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/nav_bar_background"
        android:padding="4dp">

        <Button
            android:id="@+id/btnPrev"
            style="@style/Widget.EInk.NavButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/prev_page" />

        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="@color/page_indicator"
            android:textStyle="bold"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btnNext"
            style="@style/Widget.EInk.NavButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/next_page" />

    </LinearLayout>

</LinearLayout>
